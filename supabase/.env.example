# Supabase Edge Functions local secrets
# Copy this file to supabase/.env for local function testing.

# Provided by Supabase locally when running `supabase functions serve`, but can
# be overridden for custom testing.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_local_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key

# Application-specific function secrets
SITE_URL=http://localhost:3000
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=onboarding@example.com
