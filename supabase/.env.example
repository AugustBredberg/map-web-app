# Supabase Edge Functions — used by `npm run supabase:functions:serve`
# Copy to supabase/.env (gitignored). Without `supabase functions serve`, calls to
# /functions/v1/* usually return 503 even when `supabase start` is running.
#
# Paste keys from: npm run supabase:status   (or: npx supabase status -o env)
# Use the API URL + Secret (service role) key from that output.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_local_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_local_secret_service_role_key

# Application-specific function secrets
SITE_URL=http://localhost:3000
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=onboarding@example.com
