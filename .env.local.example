# MapTiler API key — get one at https://cloud.maptiler.com/account/keys/
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_api_key_here

# Supabase project credentials — find these in your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: expose project refs in app/dev tooling (do not store passwords here)
SUPABASE_PROJECT_REF_PROD=your_prod_project_ref
SUPABASE_PROJECT_REF_DEV=your_dev_project_ref
